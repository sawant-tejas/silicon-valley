# ============================================
# Research Tracker - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# ============================================

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/researchmap
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/researchmap
MONGO_URI=mongodb://127.0.0.1:27017/researchmap

# Secret key for JWT authentication (change this to any random string)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
